#!/bin/bash
# win-hooks: patch-all
# Scans all installed Claude Code plugins and patches incompatible hooks
# for Windows compatibility. Creates run-hook.cmd polyglot wrappers and
# extensionless bash wrapper scripts. Idempotent - safe to run repeatedly.
#
# Runs at SessionStart via the win-hooks plugin hook.
# Also callable manually: bash patch-all

set -euo pipefail

# ── Platform check ──────────────────────────────────────────────────
# Only patch on Windows. On Unix/macOS, hooks work natively.
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT)
    ;; # Windows - continue
  *)
    exit 0 ;; # Not Windows - skip
esac

# ── Paths ───────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
TEMPLATE_CMD="${PLUGIN_ROOT}/hooks/run-hook.cmd"
SCRIPTS_DIR="${PLUGIN_ROOT}/scripts"

if [[ ! -f "$TEMPLATE_CMD" ]]; then
  echo "win-hooks: template run-hook.cmd not found at ${TEMPLATE_CMD}" >&2
  exit 1
fi

# ── Ensure python3 exists ───────────────────────────────────────────
# Most plugins call python3, but Windows only has python.exe.
# Copy python.exe -> python3.exe so those hooks don't fail.
if ! command -v python3 &>/dev/null && command -v python &>/dev/null; then
  python_exe="$(command -v python)"
  python_dir="$(dirname "$python_exe")"
  cp "$python_exe" "${python_dir}/python3" 2>/dev/null || true
fi

# ── Run pipeline: find-incompatible | apply-patches ─────────────────
RESULT=$(bash "${SCRIPTS_DIR}/find-incompatible" \
  | bash "${SCRIPTS_DIR}/apply-patches" "$TEMPLATE_CMD" 2>&1) || {
  echo "win-hooks: patch pipeline failed" >&2
  echo "$RESULT" >&2
  exit 1
}

# Show summary to stderr (visible in hook output)
if echo "$RESULT" | grep -q "^PATCHED:"; then
  PATCHED=$(echo "$RESULT" | grep -c "^PATCHED:")
  echo "win-hooks: patched $PATCHED plugin(s)" >&2
fi

# ── Fix backslash paths in settings.json ────────────────────────────
# Convert C:\... to C:/... in hook commands to prevent path mangling
if [[ -f "${SCRIPTS_DIR}/fix-backslash-paths" ]]; then
  bash "${SCRIPTS_DIR}/fix-backslash-paths" 2>&1 | grep -v "^hooks\." || true
fi

# ── Fix bare interpreter commands in settings.json ──────────────────
# Rewrite `node/python/python3/npx/npm <args>` to quoted absolute paths
# so hooks don't fail when cmd.exe's PATH lacks the interpreter at runtime.
if [[ -f "${SCRIPTS_DIR}/fix-bare-commands" ]]; then
  bash "${SCRIPTS_DIR}/fix-bare-commands" 2>&1 | grep -v "^hooks\." || true
fi

# ── Post-patch verification ─────────────────────────────────────────
# Run verify --fix to detect and auto-repair any remaining issues
# (BOM, CRLF, broken JSON, missing wrappers)
if [[ -x "${SCRIPTS_DIR}/verify" ]] || [[ -f "${SCRIPTS_DIR}/verify" ]]; then
  VERIFY_OUT=$(bash "${SCRIPTS_DIR}/verify" --fix 2>&1) || {
    echo "win-hooks: verify found issues (auto-fixed where possible)" >&2
    echo "$VERIFY_OUT" | grep -v "^win-hooks verify:" >&2
  }
fi
