{
  "description": "win-hooks: Auto-patches incompatible plugin hooks on Windows at session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" patch-all",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
