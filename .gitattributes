# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly force LF for scripts that bash must execute
hooks/patch-all text eol=lf
hooks/run-hook.cmd text eol=lf
scripts/find-incompatible text eol=lf
scripts/apply-patches text eol=lf
scripts/verify text eol=lf
*.sh text eol=lf
*.json text eol=lf
*.md text eol=lf
