#!/bin/bash
# win-hooks: verify
# Post-patch health check for all installed plugins' hooks.
# Detects: invalid JSON, BOM, CRLF, missing wrappers, broken references.
#
# Dependencies: only coreutils (od, sed, grep, awk) + Git Bash.
# JSON validation uses fallback chain: node (guaranteed) -> powershell -> skip.
#
# Output: tab-separated lines to stdout:
#   plugin\tinstall_path\tissue_type\tdetail
#
# Issue types:
#   bom               — UTF-8 BOM (EF BB BF) in any hook file (hooks/, _hooks/, or
#                       any file referenced from hooks.json via ${CLAUDE_PLUGIN_ROOT}/...)
#   json_invalid      — hooks.json is not valid JSON
#   json_crlf         — hooks.json contains CRLF line endings
#   wrapper_missing   — hooks.json references a _hooks/ wrapper that doesn't exist
#                       (--fix recreates it: passthrough `exec bash "$@"` when the
#                       patched command forwards the real target, else regenerated
#                       from hooks.json.bak — bash path-bake or probed-python bake)
#   wrapper_broken    — _hooks/ wrapper execs a bogus ${PLUGIN_ROOT}/<interpreter>
#                       target (path extraction grabbed the interpreter, not the
#                       script); fails with bash: .../bash: No such file or directory
#   cmd_missing       — _hooks/run-hook.cmd is missing but hooks.json references it
#   recursive_wrapper — bash wrapper (.py/.js) calls python3/node on itself
#   python3_stub      — a hook invokes bare python3/python but it resolves to a
#                       Microsoft Store App Execution Alias stub (or is missing)
#   backslash_path    — settings.json hook command contains Windows backslash paths
#   bare_command      — settings.json hook command uses bare interpreter not resolvable by cmd.exe
#
# Exit code: number of issues found (0 = healthy, capped at 125)
#
# Usage: verify [--fix]
#   --fix: auto-repair BOM/CRLF, broken/missing wrappers, and recursive wrappers in-place

set -uo pipefail

FIX_MODE=false
[[ "${1:-}" == "--fix" ]] && FIX_MODE=true

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB="${SCRIPT_DIR}/lib/plugins.sh"
if [[ ! -f "$LIB" ]]; then
  echo "win-hooks: shared lib not found: $LIB" >&2
  exit 1
fi
source "$LIB"

INSTALLED="${HOME}/.claude/plugins/installed_plugins.json"
[[ ! -f "$INSTALLED" ]] && exit 0

ISSUES_FILE=$(mktemp)
trap 'rm -f "$ISSUES_FILE"' EXIT

# ── Helpers ────────────────────────────────────────────────────────

add_issue() {
  local plugin="$1" path="$2" type="$3" detail="$4"
  printf '%s\t%s\t%s\t%s\n' "$plugin" "$path" "$type" "$detail" >> "$ISSUES_FILE"
  printf '%s\t%s\t%s\t%s\n' "$plugin" "$path" "$type" "$detail"
}

# ── Checks ─────────────────────────────────────────────────────────

check_bom() {
  local plugin="$1" install_path="$2"
  local hooks_file="${install_path}/hooks/hooks.json"
  local file_list f bom rel

  # Build deduped file list: standard hook dirs + every file the hooks.json
  # references via ${CLAUDE_PLUGIN_ROOT}/... (catches wrappers in nonstandard
  # subdirs like scripts/, bin/, etc.).
  file_list=$({
    for dir in "${install_path}/hooks" "${install_path}/_hooks"; do
      [[ -d "$dir" ]] || continue
      find "$dir" -maxdepth 1 -type f 2>/dev/null
    done
    if [[ -f "$hooks_file" ]]; then
      grep -oE '\$\{CLAUDE_PLUGIN_ROOT\}/[A-Za-z0-9_./-]+' "$hooks_file" 2>/dev/null \
        | sed "s|\${CLAUDE_PLUGIN_ROOT}|${install_path}|"
    fi
  } | sort -u)

  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ -f "$f" ]] || continue
    case "$f" in *.json.bak|*.tmp) continue ;; esac
    bom=$(od -A n -t x1 -N 3 "$f" 2>/dev/null | tr -d ' \n')
    [[ "$bom" != "efbbbf" ]] && continue
    rel="${f#$install_path/}"
    add_issue "$plugin" "$install_path" "bom" "$rel"
    if $FIX_MODE; then
      tail -c +4 "$f" > "${f}.tmp" && mv "${f}.tmp" "$f"
      echo "  FIXED: stripped BOM from $rel" >&2
    fi
  done <<< "$file_list"
}

check_crlf() {
  local plugin="$1" install_path="$2" hooks_file="$3"
  if od -c "$hooks_file" 2>/dev/null | grep -q '\\r  \\n'; then
    add_issue "$plugin" "$install_path" "json_crlf" "CRLF line endings detected"
    if $FIX_MODE; then
      sed -i 's/\r$//' "$hooks_file" 2>/dev/null || {
        sed 's/\r$//' "$hooks_file" > "${hooks_file}.tmp" && mv "${hooks_file}.tmp" "$hooks_file"
      }
      echo "  FIXED: normalized CRLF in $hooks_file" >&2
    fi
  fi
}

check_json_valid() {
  local plugin="$1" install_path="$2" hooks_file="$3"
  local err
  err=$(wh_validate_json "$hooks_file" 2>&1) || {
    add_issue "$plugin" "$install_path" "json_invalid" "$err"
    return 1
  }
  return 0
}

# Recreate a wrapper that hooks.json references but that is missing from _hooks/.
# Two cases:
#   1. The patched command forwards the real ${CLAUDE_PLUGIN_ROOT}/... target as a
#      trailing arg (older patch form). run-hook.cmd passes it through as "$@", so
#      the correct body is `exec bash "$@"`.
#   2. The path is baked into the wrapper body (current patch form, no trailing
#      target). Recover the original command from hooks.json.bak by matching the
#      generated wrapper name, then regenerate the body — probed-python bake for
#      python/python3 hooks, else a bash/direct path bake (mirrors apply-patches).
recreate_missing_wrapper() {
  local install_path="$1" hooks_file="$2" wrapper="$3" rest="$4"
  local target="${install_path}/_hooks/${wrapper}"

  # Case 1: real target forwarded as an argument.
  if printf '%s' "$rest" | grep -q 'CLAUDE_PLUGIN_ROOT'; then
    printf '#!/bin/bash\n# win-hooks: recreated — exec the real target passed by run-hook.cmd\nexec bash "$@"\n' > "$target"
    echo "  FIXED: recreated missing wrapper _hooks/${wrapper} (passthrough)" >&2
    return 0
  fi

  # Case 2: path baked in body — recover original command from .bak.
  local bak="${hooks_file}.bak" rawcmd="" relpath interp py b p l
  if [[ ! -f "$bak" ]]; then
    echo "  WARN: cannot recreate _hooks/${wrapper} — no hooks.json.bak" >&2
    return 1
  fi
  while IFS= read -r l; do
    p=$(printf '%s' "$l" | grep -oE '\$\{CLAUDE_PLUGIN_ROOT\}/[A-Za-z0-9_./-]+' | head -1)
    [[ -z "$p" ]] && continue
    b=$(basename "$p"); b="${b%.*}"; b="${b//_/-}"
    if [[ "$b" == "$wrapper" ]]; then rawcmd="$l"; break; fi
  done < <(grep -E '"command"' "$bak" 2>/dev/null)
  if [[ -z "$rawcmd" ]]; then
    echo "  WARN: cannot map _hooks/${wrapper} to a hooks.json.bak command" >&2
    return 1
  fi
  relpath=$(printf '%s' "$rawcmd" | grep -oE '\$\{CLAUDE_PLUGIN_ROOT\}/[A-Za-z0-9_./-]+' | head -1 | sed 's|.*${CLAUDE_PLUGIN_ROOT}/||')
  interp=$(printf '%s' "$rawcmd" | sed -E 's/.*"command"[[:space:]]*:[[:space:]]*"//' | awk '{print $1}' | tr -d '\\"')
  if [[ "$interp" == "python3" || "$interp" == "python" ]]; then
    py=$(wh_resolve_python)
    if [[ -n "$py" ]]; then
      printf '#!/bin/bash\nSCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"\nPLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"\nexec "%s" "$PLUGIN_ROOT/%s" "$@"\n' "$py" "$relpath" > "$target"
    else
      printf '#!/bin/bash\n# win-hooks: no working Python found — graceful no-op\nexit 0\n' > "$target"
    fi
  elif [[ "$relpath" == *.sh || "$interp" == "bash" || "$interp" == "sh" ]]; then
    printf '#!/bin/bash\nSCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"\nPLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"\nexec bash "$PLUGIN_ROOT/%s" "$@"\n' "$relpath" > "$target"
  else
    printf '#!/bin/bash\nSCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"\nPLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"\nexec "$PLUGIN_ROOT/%s" "$@"\n' "$relpath" > "$target"
  fi
  echo "  FIXED: recreated missing wrapper _hooks/${wrapper} (regenerated from .bak)" >&2
}

check_wrappers() {
  local plugin="$1" install_path="$2" hooks_file="$3"
  local hooks_dir="${install_path}/_hooks"
  # Each patched command looks like:
  #   "\"${CLAUDE_PLUGIN_ROOT}/_hooks/run-hook.cmd\" <wrapper> [<trailing target>]"
  # The escaped \" right after run-hook.cmd defeated an [^"]* grab (it stopped at
  # that quote, losing the wrapper name), so wrapper_missing never fired for the
  # normal patched form. Parse per line: strip up to run-hook.cmd plus the escaped
  # quote/space, then take the first token as the wrapper name.
  # Require the _hooks/ segment so we only manage win-hooks-created wrappers — a
  # plugin that ships its own polyglot at hooks/run-hook.cmd (e.g. superpowers)
  # must NOT be flagged.
  grep -E '_hooks/run-hook\.cmd' "$hooks_file" 2>/dev/null | while IFS= read -r line; do
    local rest wrapper
    rest=$(printf '%s' "$line" | sed -E 's/.*run-hook\.cmd//; s/^[\\"]*[[:space:]]*//')
    wrapper=$(printf '%s' "$rest" | awk '{print $1}' | sed 's/[\\"].*//')
    [[ -z "$wrapper" ]] && continue

    if [[ ! -f "${hooks_dir}/run-hook.cmd" ]]; then
      add_issue "$plugin" "$install_path" "cmd_missing" "_hooks/run-hook.cmd not found"
    fi
    if [[ ! -f "${hooks_dir}/${wrapper}" ]]; then
      add_issue "$plugin" "$install_path" "wrapper_missing" "_hooks/${wrapper} not found"
      if $FIX_MODE; then
        recreate_missing_wrapper "$install_path" "$hooks_file" "$wrapper" "$rest"
      fi
    fi
  done
}

check_recursive_wrapper() {
  local plugin="$1" install_path="$2"
  for dir in "${install_path}/hooks" "${install_path}/_hooks"; do
    [[ ! -d "$dir" ]] && continue
    for f in "$dir"/*.py "$dir"/*.js; do
      [[ ! -f "$f" ]] && continue
      # Check if it's actually a bash script (not real Python/JS)
      local first_line
      first_line=$(head -c 64 "$f" | tr -d '\r' | sed 's/^\xEF\xBB\xBF//' | head -1)
      [[ "$first_line" != "#!/bin/bash"* && "$first_line" != "#!/usr/bin/env bash"* ]] && continue
      # Check if the script calls python3/node on the same filename
      local base
      base=$(basename "$f")
      if grep -qE "(python3?|node)[[:space:]].*${base}" "$f" 2>/dev/null; then
        add_issue "$plugin" "$install_path" "recursive_wrapper" "${base} calls interpreter on itself"
        if $FIX_MODE; then
          printf '#!/bin/bash\n# win-hooks: disabled — bash wrapper called interpreter on itself\nexit 0\n' > "$f"
          echo "  FIXED: disabled recursive wrapper ${base}" >&2
        fi
      fi
    done
  done
}

# Detect _hooks/ wrappers that exec a bogus single-segment ${PLUGIN_ROOT}/<X>
# target. Caused by an older apply-patches grabbing the interpreter (e.g. `bash`)
# from a command like `bash ${CLAUDE_PLUGIN_ROOT}/x.sh` as the script path, so the
# wrapper runs `exec bash "$PLUGIN_ROOT/bash"` — a file that does not exist. Symptom:
# `bash: .../<plugin>/<ver>/bash: No such file or directory`. The real target is
# still passed as $@ by run-hook.cmd, so repair = exec that instead.
check_wrapper_bodies() {
  local plugin="$1" install_path="$2"
  local dir="${install_path}/_hooks"
  [[ -d "$dir" ]] || return 0
  local f base seg rel
  for f in "$dir"/*; do
    [[ -f "$f" ]] || continue
    base=$(basename "$f")
    [[ "$base" == "run-hook.cmd" ]] && continue
    # Broken wrapper from JSON-escaped quote leakage:
    #   bash \"$CLAUDE_PLUGIN_ROOT\"/hooks/x.sh
    # The backslashes make the quotes literal, so bash tries to open a path
    # containing quote characters. Regenerate it as the normal path-baked body.
    rel=$(sed -nE 's#.*\\"\$CLAUDE_PLUGIN_ROOT\\"/([A-Za-z0-9_./-]+).*#\1#p' "$f" 2>/dev/null | head -1)
    if [[ -n "$rel" ]]; then
      add_issue "$plugin" "$install_path" "wrapper_broken" "_hooks/${base} contains literal escaped quotes around CLAUDE_PLUGIN_ROOT"
      if $FIX_MODE; then
        if [[ "$rel" == *.sh ]]; then
          printf '#!/bin/bash\nSCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"\nPLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"\nexec bash "$PLUGIN_ROOT/%s" "$@"\n' "$rel" > "$f"
        else
          printf '#!/bin/bash\nSCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"\nPLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"\nexec "$PLUGIN_ROOT/%s" "$@"\n' "$rel" > "$f"
        fi
        echo "  FIXED: repaired escaped-quote wrapper _hooks/${base}" >&2
      fi
      continue
    fi
    # Bogus target = a single path segment (no slash) right after $PLUGIN_ROOT/.
    seg=$(grep -oE 'exec ([^ "]+ )?"\$PLUGIN_ROOT/[^"/]+"' "$f" 2>/dev/null | head -1 \
      | sed -E 's#.*\$PLUGIN_ROOT/([^"/]+)".*#\1#')
    [[ -z "$seg" ]] && continue
    # Broken if that segment is a bare interpreter name, or the file is absent.
    if [[ "$seg" =~ ^(bash|sh|python3?|node|npx|npm)$ ]] || [[ ! -e "${install_path}/${seg}" ]]; then
      add_issue "$plugin" "$install_path" "wrapper_broken" "_hooks/${base} execs nonexistent \$PLUGIN_ROOT/${seg}"
      if $FIX_MODE; then
        printf '#!/bin/bash\n# win-hooks: repaired — exec the real target passed by run-hook.cmd\nexec bash "$@"\n' > "$f"
        echo "  FIXED: repaired broken wrapper _hooks/${base}" >&2
      fi
    fi
  done
}

# Detect an unwrapped hook that invokes a bare python3/python interpreter for
# which NO working Python exists. apply-patches normally wraps such hooks (and
# the wrapper falls back across python3/python/py), so this only fires for an
# unpatched hook on a machine with no usable interpreter — e.g. python3 is only
# a dead Microsoft Store App Execution Alias stub and there is no other Python.
# Detection uses a functional probe (`-c ""`), not a path heuristic, so a real
# Store-installed Python is not misreported.
check_python3_stub() {
  local plugin="$1" install_path="$2" hooks_file="$3"
  # Does any (still-bare) hook command start with python3/python?
  grep -qE '"command":[[:space:]]*"python3?[[:space:]]' "$hooks_file" 2>/dev/null || return 0
  local _py
  for _py in python3 python py; do
    command -v "$_py" >/dev/null 2>&1 && "$_py" -c "" >/dev/null 2>&1 && return 0
  done
  add_issue "$plugin" "$install_path" "python3_stub" "hook uses python but no working python3/python/py is available"
}

# ── Main scan ──────────────────────────────────────────────────────

while IFS=$'\t' read -r plugin install_path hooks_file; do
  # Run checks (fix BOM/CRLF before JSON validation)
  check_bom "$plugin" "$install_path"
  check_crlf "$plugin" "$install_path" "$hooks_file"
  check_recursive_wrapper "$plugin" "$install_path"
  check_wrapper_bodies "$plugin" "$install_path"
  check_python3_stub "$plugin" "$install_path" "$hooks_file"
  if check_json_valid "$plugin" "$install_path" "$hooks_file"; then
    check_wrappers "$plugin" "$install_path" "$hooks_file"
  fi
done < <(wh_each_plugin_hooksjson "$INSTALLED")

# ── Check settings.json for backslash paths and bare commands ─────

SETTINGS="${HOME}/.claude/settings.json"
if [[ -f "$SETTINGS" ]] && command -v node &>/dev/null; then
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  if [[ -f "${SCRIPT_DIR}/fix-backslash-paths" ]]; then
    bash "${SCRIPT_DIR}/fix-backslash-paths" --dry-run 2>/dev/null | while IFS=$'\t' read -r location old_cmd new_cmd; do
      add_issue "settings.json" "$SETTINGS" "backslash_path" "${location}: ${old_cmd}"
    done
  fi
  if [[ -f "${SCRIPT_DIR}/fix-bare-commands" ]]; then
    bash "${SCRIPT_DIR}/fix-bare-commands" --dry-run 2>/dev/null | while IFS=$'\t' read -r location old_cmd new_cmd; do
      add_issue "settings.json" "$SETTINGS" "bare_command" "${location}: ${old_cmd}"
    done
  fi
fi

# ── Summary ────────────────────────────────────────────────────────

issues=$(wc -l < "$ISSUES_FILE" | tr -d ' ')
if [[ "$issues" -eq 0 ]]; then
  echo "win-hooks verify: all plugins healthy" >&2
else
  echo "win-hooks verify: $issues issue(s) found" >&2
fi

exit $(( issues > 125 ? 125 : issues ))
