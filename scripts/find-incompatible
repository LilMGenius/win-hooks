#!/bin/bash
# win-hooks: find-incompatible
# Scans installed Claude Code plugins for hooks with Windows-incompatible commands.
# Outputs tab-separated lines: plugin\tinstall_path\thooks_file\tevent\tcommand
# Empty output means all plugins are compatible.
#
# The command field contains the value as it appears in the JSON file (with any
# JSON escaping like \" intact), so apply-patches can do exact string matching.

INSTALLED="${HOME}/.claude/plugins/installed_plugins.json"
[[ ! -f "$INSTALLED" ]] && exit 0

# Strip UTF-8 BOM (EF BB BF) if present — common on Windows
strip_bom() { sed '1s/^\xEF\xBB\xBF//'; }

# Check if a hook command is incompatible with Windows.
# Returns 0 (true) if incompatible, 1 (false) if compatible.
is_incompatible() {
  local cmd="$1"
  [[ -z "$cmd" ]] && return 1
  # Already uses .cmd wrapper
  [[ "$cmd" == *".cmd"* ]] && return 1
  # Direct .sh call
  [[ "$cmd" == *".sh"* ]] && return 0
  # CLAUDE_PLUGIN_ROOT path
  if [[ "$cmd" == *'${CLAUDE_PLUGIN_ROOT}'* ]]; then
    local first_word
    first_word=$(printf '%s' "$cmd" | awk '{print $1}' | tr -d "\"'\\\\")
    case "$first_word" in
      python3|python|node|npx|npm) return 1 ;;
    esac
    [[ "$cmd" == *".py"* ]] && return 1
    return 0
  fi
  # Bare command — check if binary exists on PATH
  local first_word
  first_word=$(printf '%s' "$cmd" | awk '{print $1}')
  if [[ "$first_word" != *"/"* && "$first_word" != *'$'* && "$first_word" != *"\\"* ]]; then
    command -v "$first_word" &>/dev/null || return 0
  fi
  return 1
}

# Parse installed_plugins.json — output: plugin_name\tinstall_path
parse_plugins() {
  strip_bom < "$INSTALLED" | awk '
    /": \[/ {
      sub(/^[[:space:]]*"/, "")
      sub(/".*/, "")
      plugin = $0
      next
    }
    /"installPath"/ {
      sub(/.*"installPath"[[:space:]]*:[[:space:]]*"/, "")
      sub(/".*/, "")
      path = $0
      if (plugin != "" && path != "") print plugin "\t" path
    }
  ' | sed 's/[\\][\\]*/\//g'
}

# Extract hook commands from a hooks.json file — output: event\tcommand
extract_commands() {
  local hooks_file="$1"
  local current_event=""
  local re_event='"([A-Za-z]+)":[[:space:]]*\['
  local re_cmd='"command":[[:space:]]*"(.*)"[,[:space:]]*$'

  while IFS= read -r line; do
    if [[ "$line" =~ $re_event ]]; then
      [[ "${BASH_REMATCH[1]}" != "hooks" ]] && current_event="${BASH_REMATCH[1]}"
    fi
    if [[ "$line" =~ $re_cmd ]]; then
      local cmd="${BASH_REMATCH[1]}"
      [[ -n "$current_event" && -n "$cmd" ]] && printf '%s\t%s\n' "$current_event" "$cmd"
    fi
  done < <(strip_bom < "$hooks_file")
}

# Main: scan all plugins
parse_plugins | while IFS=$'\t' read -r plugin install_path; do
  [[ "$plugin" == *"win-hooks"* ]] && continue
  hooks_file="${install_path}/hooks/hooks.json"
  [[ ! -f "$hooks_file" ]] && continue

  extract_commands "$hooks_file" | while IFS=$'\t' read -r event cmd; do
    if is_incompatible "$cmd"; then
      printf '%s\t%s\t%s\t%s\t%s\n' "$plugin" "$install_path" "$hooks_file" "$event" "$cmd"
    fi
  done
done
